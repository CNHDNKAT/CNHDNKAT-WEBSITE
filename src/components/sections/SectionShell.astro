---
import type { MainSectionEntry } from "../../lib/content";

interface Props {
  entry: MainSectionEntry;
  Content?: unknown;
}

const { entry, Content } = Astro.props;
const ContentComponent = Content as any;
const HeadingTag = entry.data.slug === "about" ? "h1" : "h2";
const hasBody = typeof entry.body === "string" && entry.body.trim().length > 0;
const hasHeaderActions = Astro.slots.has("header-actions");
---

<section id={entry.data.slug} class="section">
  <div class="section-header">
    <HeadingTag>
      <span class="hash">#</span>
      {entry.data.nav_label ?? entry.data.slug}
    </HeadingTag>
  </div>
  <div class="section-meta">last_modified: {entry.data.last_modified}</div>
  {hasHeaderActions && (
    <div class="section-header-actions">
      <slot name="header-actions" />
    </div>
  )}

  {hasBody && ContentComponent && <ContentComponent />}

  <slot />
</section>
