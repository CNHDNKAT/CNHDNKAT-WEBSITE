---
import type { MainSectionEntry } from "../../lib/content";
import { typografText } from "../../lib/typograf";
import CopyToast from "../CopyToast.astro";
import PromptCopyButton from "../PromptCopyButton.astro";
import SectionShell from "./SectionShell.astro";

interface Props {
  entry: MainSectionEntry;
  Content?: unknown;
  prompt: string;
}

const { entry, Content, prompt } = Astro.props;
const toastId = "copy-toast";
const webhookUrl =
  "https://n8n.khabaroff.com/webhook/586a1568-5779-40bf-98ab-bd222fb82798";
const formId = "dialog-link-form";
const inputId = "dialog-link-input";
const telegramInputId = "telegram-username-input";
const statusId = "dialog-link-status";
---

<SectionShell entry={entry} Content={Content}>
  <PromptCopyButton slot="header-actions" prompt={prompt} toastId={toastId} />

  <div class="steps">
    {
      entry.data.steps?.map((step, index) => (
          <div class="step">
            <div class="step-num">{index + 1}.</div>
          <div class="step-text">{typografText(step)}</div>
        </div>
      ))
    }
  </div>

  <div class="cta-area">
    <form
      id={formId}
      class="dialog-link-form"
      data-dialog-link-form
      data-status-id={statusId}
      data-webhook-url={webhookUrl}
    >
      <div class="dialog-link-inline">
        <input
          id={inputId}
          class="dialog-link-input"
          name="dialogUrl"
          type="text"
          inputmode="url"
          autocomplete="url"
          placeholder="https://chatgpt.com/share/..."
          pattern="https://.*"
          title="Ссылка должна начинаться с https://"
          required
        />
        <input
          id={telegramInputId}
          class="dialog-link-input dialog-link-input-telegram"
          name="telegramUsername"
          type="text"
          inputmode="text"
          autocomplete="username"
          placeholder="@nickname"
          required
        />
        <button class="btn btn-mail" type="submit">{typografText("→ отправить ссылку на диалог")}</button>
      </div>
      <p id={statusId} class="dialog-link-status" aria-live="polite"></p>
    </form>
  </div>

  {entry.data.aside && <div class="note">{typografText(entry.data.aside)}</div>}

  <CopyToast id={toastId} />
</SectionShell>

<script is:inline>
  const setDialogLinkStatus = (element, message, state) => {
    if (!(element instanceof HTMLElement)) {
      return;
    }

    element.textContent = message;
    element.dataset.state = state;
  };

  document.querySelectorAll("[data-dialog-link-form]").forEach((form) => {
    if (!(form instanceof HTMLFormElement) || form.dataset.dialogLinkBound === "true") {
      return;
    }

    form.dataset.dialogLinkBound = "true";

    const dialogUrlInput = form.querySelector("[name='dialogUrl']");
    const telegramUsernameInput = form.querySelector("[name='telegramUsername']");
    const statusId = form.dataset.statusId ?? "";
    const status = statusId ? document.getElementById(statusId) : null;
    const webhookUrl = form.dataset.webhookUrl ?? "";

    form.addEventListener("submit", (event) => {
      event.preventDefault();

      if (
        !(dialogUrlInput instanceof HTMLInputElement) ||
        !(telegramUsernameInput instanceof HTMLInputElement)
      ) {
        return;
      }

      const dialogUrl = dialogUrlInput.value.trim();
      const telegramUsername = telegramUsernameInput.value.trim();

      if (!dialogUrl.startsWith("https://")) {
        setDialogLinkStatus(status, "Ссылка должна начинаться с https://", "error");
        dialogUrlInput.focus();
        return;
      }

      if (telegramUsername.length === 0) {
        setDialogLinkStatus(status, "Укажи Telegram username.", "error");
        telegramUsernameInput.focus();
        return;
      }

      const requestUrl = `${webhookUrl}?${new URLSearchParams({ dialogUrl, telegramUsername })}`;
      const beacon = new Image();
      beacon.src = requestUrl;

      dialogUrlInput.value = "";
      telegramUsernameInput.value = "";
      setDialogLinkStatus(status, "Ссылка отправлена.", "success");
    });
  });
</script>
