---
import type { MainSectionEntry } from "../../lib/content";
import { typografText } from "../../lib/typograf";
import SectionShell from "./SectionShell.astro";

interface Props {
  entry: MainSectionEntry;
  Content?: unknown;
}

const { entry, Content } = Astro.props;
---

<SectionShell entry={entry} Content={Content}>
  {
    entry.data.subsections?.map((subsection) => (
      <div class="subsection">
        <h3>
          <span class="hash">##</span>
          {typografText(subsection.title)}
        </h3>
        {subsection.meta && <div class="subsection-meta">{typografText(subsection.meta)}</div>}

        <div class="lab-card">
          {subsection.badges.length > 0 && (
            <div class="lab-badges">
              {subsection.badges.map((badge) => (
                <span class="lab-badge">{typografText(badge)}</span>
              ))}
            </div>
          )}

          {subsection.paragraphs.map((paragraph) => (
            <p>{typografText(paragraph)}</p>
          ))}
        </div>
      </div>
    ))
  }
</SectionShell>
