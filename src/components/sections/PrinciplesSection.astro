---
import type { MainSectionEntry } from "../../lib/content";
import SectionShell from "./SectionShell.astro";

interface Props {
  entry: MainSectionEntry;
  Content?: unknown;
}

const { entry, Content } = Astro.props;
---

<SectionShell entry={entry} Content={Content}>
  <div class="principle-list">
    {
      entry.data.principles?.map((principle) => (
        <article class="principle-card">
          <div class="principle-num">{principle.number}</div>
          <div class="principle-title">
            {principle.title}
            {principle.proposed && <span class="tag-proposed">proposed</span>}
          </div>
          <p>{principle.body}</p>
        </article>
      ))
    }
  </div>
</SectionShell>
