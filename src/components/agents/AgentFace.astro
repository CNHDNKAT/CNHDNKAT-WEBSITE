---
import BalthasarFace from "./BalthasarFace.astro";
import CasparFace from "./CasparFace.astro";
import MelchiorFace from "./MelchiorFace.astro";

interface Props {
  slug?: string;
  name?: string;
}

const { slug = "", name = "" } = Astro.props;
const normalized = slug || name.toLowerCase();
---

{
  normalized === "caspar" ? (
    <CasparFace />
  ) : normalized === "melchior" ? (
    <MelchiorFace />
  ) : (
    <BalthasarFace />
  )
}
