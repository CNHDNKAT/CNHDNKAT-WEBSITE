---
import { typografText } from "../lib/typograf";

interface Props {
  id?: string;
  message?: string;
}

const { id = "copy-toast", message = "Промпт скопирован" } = Astro.props;
const formattedMessage = typografText(message);
---

<div id={id} class="toast" aria-live="polite" aria-atomic="true">
  {formattedMessage}
</div>
